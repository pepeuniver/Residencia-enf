function nrd(status,id){
  if(!['estudei','questoes','revisado'].includes(status))return null;
  const s=gs(id);const stage=status==='revisado'?Math.min((s.srStage||0),SR_INT.length-1):0;
  const d=new Date();d.setDate(d.getDate()+SR_INT[stage]);return d.toISOString();
}
function renderSubjRow(s,rank){
  const st=gs(s.id),due=isDue(s.id);
  let nrt='';
  if(st.lastStudied&&['estudei','questoes','revisado'].includes(st.status)){
    const nd=getNextSRDate(s.id);
    if(nd){const df=Math.ceil((nd-new Date())/86400000);if(df<=0)nrt=`<span class="rev-badge-s">Revisar hoje!</span>`;else if(df===1)nrt=`<span class="nxt-rev">Rev. amanhã</span>`;else nrt=`<span class="nxt-rev">Rev. em ${df}d</span>`;}
  }
  const opts=SOPTS.map(o=>`<option value="${o.v}"${st.status===o.v?' selected':''}>${o.l}</option>`).join('');
  const qd=QDATA[s.id];const hasQ=qd&&qd.length>0;
  const r=rank<=2?1:rank<=5?2:rank<=10?3:4;
  return`<div class="subj-item${due?' due':''}" id="si-${s.id}">
    <div class="rank r${r}">${rank}</div>
    <div>
      <div class="subj-name">${s.name}</div>
      <div class="subj-meta">${dstars(s.id,s.d)}${nrt}</div>
