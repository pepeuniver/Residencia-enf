  {id:'e32',name:'Procedimentos básicos: Sondagens, curativos, medicamentos, oxigenoterapia',d:1},
  {id:'e33',name:'Cuidados e riscos ao adulto, idoso e criança em uso de medicamentos',d:2},
];
const ALL=[...US,...ES];

// SR intervals in days
const SR_INT=[1,3,7,14,30];
const SR_COLORS=['r1','r2','r3','r4','r5'];
const SR_LABELS=['1ª revisão','2ª revisão','3ª revisão','4ª revisão','5ª revisão'];
const DC=['','#4ade80','#38bdf8','#f59e0b','#f87171'];
const DL=['','Fácil','Médio','Difícil','Muito Difícil'];
const SOPTS=[{v:'nao-estudado',l:'○ Não estudado'},{v:'estudando',l:'◑ Estudando'},{v:'estudei',l:'◕ Estudei'},{v:'questoes',l:'✦ Questões'},{v:'revisado',l:'✓ Revisado'}];
const CIRC=2*Math.PI*110;

// ════════ STATE ════════
let ST={},LOGS=[],DAYS=[],SDONE={},QDATA={},SYNC_CODE='';

function genCode(){const c='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';let s='';for(let i=0;i<8;i++){if(i===4)s+='-';s+=c[Math.floor(Math.random()*c.length)]}return s}

function load(){
  try{ST=JSON.parse(localStorage.getItem('enf4_st')||'{}')}catch(e){ST={}}
  try{const l=JSON.parse(localStorage.getItem('enf4_logs')||'[]');const t=new Date().toDateString();LOGS=l.filter(x=>new Date(x.ts).toDateString()===t)}catch(e){LOGS=[]}
  try{DAYS=JSON.parse(localStorage.getItem('enf4_days')||'[]')}catch(e){DAYS=[]}
  try{SDONE=JSON.parse(localStorage.getItem('enf4_sd')||'{}')}catch(e){SDONE={}}
  try{QDATA=JSON.parse(localStorage.getItem('enf4_q')||'{}')}catch(e){QDATA={}}
  SYNC_CODE=localStorage.getItem('enf4_code')||'';
  if(!SYNC_CODE){SYNC_CODE=genCode();localStorage.setItem('enf4_code',SYNC_CODE)}
  document.getElementById('syncCodeDisplay').textContent='🔗 '+SYNC_CODE;
  document.getElementById('modalSyncCode').textContent=SYNC_CODE;
}
function save(){
  localStorage.setItem('enf4_st',JSON.stringify(ST));
  localStorage.setItem('enf4_logs',JSON.stringify(LOGS));
  localStorage.setItem('enf4_days',JSON.stringify(DAYS));
  localStorage.setItem('enf4_sd',JSON.stringify(SDONE));
  localStorage.setItem('enf4_q',JSON.stringify(QDATA));
  // Also persist across code for sync (using localStorage keyed by code)
  const blob={ST,DAYS,SDONE,QDATA,ts:Date.now()};
  localStorage.setItem('sync_'+SYNC_CODE,JSON.stringify(blob));
}
function gs(id){return ST[id]||{status:'nao-estudado',userDiff:0,srStage:0,srDates:[],lastStudied:null}}
function ss2(id,u){ST[id]={...gs(id),...u};save()}

function pad(n){return String(n).padStart(2,'0')}
function fmt(s){return`${pad(Math.floor(s/3600))}:${pad(Math.floor((s%3600)/60))}:${pad(s%60)}`}
function dk(d){return`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`}
function tdk(){return dk(new Date())}
function addDays(d,n){const r=new Date(d);r.setDate(r.getDate()+n);return r}

// ════════ SYNC ════════
function openSyncModal(){document.getElementById('syncModal').classList.add('open')}
function closeSyncModal(){document.getElementById('syncModal').classList.remove('open')}
function formatSyncInput(el){let v=el.value.toUpperCase().replace(/[^A-Z0-9]/g,'');if(v.length>4)v=v.slice(0,4)+'-'+v.slice(4,8);el.value=v}
function doImportSync(){
  const code=document.getElementById('syncImportInput').value.trim().toUpperCase();
  const st=document.getElementById('syncStatus');
  if(code.length<9){st.textContent='⚠ Insira um código válido (XXXX-XXXX)';st.style.color='var(--accent3)';return}
  // Try local first (same browser / different tab)
  const localData=localStorage.getItem('sync_'+code);
  if(localData){
    try{
      const d=JSON.parse(localData);
      if(d.ST)ST=d.ST;if(d.DAYS)DAYS=d.DAYS;if(d.SDONE)SDONE=d.SDONE;if(d.QDATA)QDATA=d.QDATA;
      save();
      st.textContent='✓ Dados importados com sucesso!';st.style.color='var(--accent)';
      setTimeout(()=>{closeSyncModal();renderAll()},1200);
    }catch(e){st.textContent='⚠ Erro ao importar dados.';st.style.color='var(--accent4)'}
    return;
  }
  // Export instructions
  st.innerHTML='ℹ Para sincronizar entre dispositivos diferentes:<br>1. No dispositivo original, abra o site<br>2. Pressione F12 → Console<br>3. Cole: <code style="color:var(--accent2)">copy(localStorage.getItem("sync_'+code+'"))</code><br>4. Neste dispositivo, pressione F12 → Console e cole o resultado';
  st.style.color='var(--muted)';
}

// ════════ NAV ════════
function showPage(i){
  document.querySelectorAll('.page').forEach((p,j)=>p.classList.toggle('active',j===i));
  document.querySelectorAll('.nav-tab').forEach((t,j)=>t.classList.toggle('active',j===i));
  if(i===1){renderSR()}
  if(i===2){renderCal();renderStreak();renderHM()}
  if(i===3){renderSched()}
  if(i===4){renderSubjs()}
  if(i===5){renderPerf()}
}
function renderAll(){renderSR();renderCal();renderStreak();renderHM();renderSched();renderSubjs();renderPerf()}

// ════════ TIMER ════════
let tSec=0,tRun=false,tIv=null;
function timerPlayPause(){
  if(tRun){
    tRun=false;clearInterval(tIv);
    document.getElementById('tPlayBtn').textContent='▶';
    document.getElementById('tPlayBtn').className='tcbtn lg play';
    document.getElementById('tState').textContent='Pausado';
  } else {
    tRun=true;
    document.getElementById('tPlayBtn').textContent='⏸';
    document.getElementById('tPlayBtn').className='tcbtn lg pause';
    document.getElementById('tState').textContent='Estudando...';
    tIv=setInterval(()=>{tSec++;tickTimer()},1000);
    autoCI();
    const pk=document.getElementById('subjectPicker'),sid=pk.value;
    const sn=sid?(ALL.find(s=>s.id===sid)?.name||'Sessão Livre'):'Sessão Livre';
    document.getElementById('tSubjName').textContent=sn.length>60?sn.slice(0,60)+'…':sn;
    document.getElementById('tSubjSub').textContent='Em andamento...';
    document.querySelectorAll('.tim-btn').forEach(b=>b.classList.remove('active'));
    if(sid)document.getElementById('si-'+sid)?.querySelector('.tim-btn')?.classList.add('active');
  }
}
function timerStop(){
  if(tSec>0){
    const pk=document.getElementById('subjectPicker'),sid=pk.value;
    const sn=sid?(ALL.find(s=>s.id===sid)?.name||'Sessão Livre'):'Sessão Livre';
    LOGS.push({id:sid||'free',name:sn,duration:tSec,ts:new Date().toISOString()});
    save();renderLogs();
  }
  tRun=false;clearInterval(tIv);tSec=0;
  document.getElementById('tPlayBtn').textContent='▶';
  document.getElementById('tPlayBtn').className='tcbtn lg play';
  document.getElementById('tState').textContent='Pronto';
  document.getElementById('tSubjName').textContent='Sessão Livre';
  document.getElementById('tSubjSub').textContent='Pressione ▶ para iniciar sem selecionar matéria';
  tickTimer();
  document.querySelectorAll('.tim-btn').forEach(b=>b.classList.remove('active'));
}
function timerReset(){tRun=false;clearInterval(tIv);tSec=0;document.getElementById('tPlayBtn').textContent='▶';document.getElementById('tPlayBtn').className='tcbtn lg play';document.getElementById('tState').textContent='Pronto';tickTimer()}
function tickTimer(){
  document.getElementById('tDigits').textContent=fmt(tSec);
  const pct=Math.min(tSec/3600,1),offset=CIRC*(1-pct);
  const ring=document.getElementById('tRing');
  ring.style.strokeDashoffset=offset;
  const col=tSec<1800?'var(--accent)':tSec<3000?'var(--accent3)':'var(--accent4)';
  ring.style.stroke=col;document.getElementById('tDigits').style.color=col;
}
function renderLogs(){
  const el=document.getElementById('logList');
  if(!LOGS.length){el.innerHTML='<div class="log-entry"><span class="log-name" style="color:var(--muted)">Nenhuma sessão ainda</span></div>';document.getElementById('todayTotal').textContent='00:00:00';return}
  el.innerHTML=LOGS.slice().reverse().map(l=>`<div class="log-entry"><span class="log-name">${l.name}</span><span class="log-time">${fmt(l.duration)}</span></div>`).join('');
  document.getElementById('todayTotal').textContent=fmt(LOGS.reduce((a,b)=>a+b.duration,0));
}
function startTimerFor(id){document.getElementById('subjectPicker').value=id;showPage(0);if(!tRun)timerPlayPause()}
function populatePicker(){
  const ug=document.getElementById('uerjOG'),eg=document.getElementById('enareOG');
  US.forEach(s=>{const o=document.createElement('option');o.value=s.id;o.textContent=s.name.length>62?s.name.slice(0,62)+'…':s.name;ug.appendChild(o)});
  ES.forEach(s=>{const o=document.createElement('option');o.value=s.id;o.textContent=s.name.length>62?s.name.slice(0,62)+'…':s.name;eg.appendChild(o)});
}

// ════════ SPACED REPETITION ════════
function getSRDates(id){
  const s=gs(id);
  if(!s.lastStudied||!['estudei','questoes','revisado'].includes(s.status))return null;
  const base=new Date(s.lastStudied);
  return SR_INT.map(d=>({date:addDays(base,d),stage:SR_INT.indexOf(d)}));
}
function getNextSRDate(id){
  const s=gs(id);
  if(!s.lastStudied||s.status==='nao-estudado'||s.status==='estudando')return null;
  const stage=Math.min(s.srStage||0,SR_INT.length-1);
  const base=s.srLastDone?new Date(s.srLastDone):new Date(s.lastStudied);
  return addDays(base,SR_INT[stage]);
}
function isDue(id){
  const nd=getNextSRDate(id);
  return nd&&nd<=new Date();
}
function isDueOn(id,date){
  const s=gs(id);
  if(!s.lastStudied||s.status==='nao-estudado'||s.status==='estudando')return false;
  const dates=getSRDates(id);
  if(!dates)return false;
  return dates.some(d=>dk(d.date)===dk(date));
}
function renderSR(){
  const today=new Date();
  const todayDue=ALL.filter(s=>isDue(s.id));
  document.getElementById('srTodayCount').textContent=todayDue.length;
  const tList=document.getElementById('srTodayList');
  if(!todayDue.length){
    tList.innerHTML='<div style="font-size:0.8rem;color:var(--muted);padding:0.5rem">✨ Nenhuma revisão pendente para hoje. Continue estudando novas matérias!</div>';
  } else {
    tList.innerHTML=todayDue.map(s=>{
      const stage=gs(s.id).srStage||0;
      const done=gs(s.id).srTodayDone;
      return`<div class="sr-item">
        <div class="sr-item-name">${s.name}</div>
        <div class="sr-item-stage">${SR_LABELS[stage]}</div>
        <button class="sr-do-btn${done?' done-btn':''}" onclick="markSRDone('${s.id}',this)">${done?'✓ Feito':'Revisar'}</button>
      </div>`;
    }).join('');
  }

  // Build 14-day timeline
  const days=[];
  for(let i=0;i<14;i++){const d=new Date(today);d.setDate(d.getDate()+i);days.push(d)}
  const grouped={};
  ALL.forEach(s=>{
    const dates=getSRDates(s.id);
    if(!dates)return;
    dates.forEach(({date,stage})=>{
      const k=dk(date);
      if(!grouped[k])grouped[k]=[];
      grouped[k].push({name:s.name,stage});
    });
  });
  const tl=document.getElementById('srTimeline');
  const futureDays=days.filter(d=>Object.keys(grouped).includes(dk(d)));
  if(!futureDays.length){
    tl.innerHTML='<div style="font-size:0.8rem;color:var(--muted);padding:0.75rem">Nenhuma revisão agendada nos próximos 14 dias. Estude mais matérias para gerar revisões!</div>';
    return;
  }
  let html='<div class="sr-timeline">';
  days.forEach(d=>{
    const k=dk(d);const tasks=grouped[k]||[];if(!tasks.length)return;
    const isT=d.toDateString()===today.toDateString();
    const wday=d.toLocaleDateString('pt-BR',{weekday:'short'}).replace('.','');
    const dateStr=`${d.getDate()}/${d.getMonth()+1}`;
    html+=`<div class="sr-tl-row">
      <div class="sr-tl-date" style="${isT?'background:rgba(74,222,128,0.07)':''}">
        <div class="sr-tl-date-day" style="${isT?'color:var(--accent)':''}">${dateStr}</div>
        <div class="sr-tl-date-wday">${wday}</div>
      </div>
      <div class="sr-tl-tasks">`;
    tasks.slice(0,4).forEach(t=>{
      html+=`<div class="sr-tl-task ${SR_COLORS[t.stage]}"><span class="sr-stage-dot" style="background:currentColor"></span>${t.name.length>55?t.name.slice(0,55)+'…':t.name}</div>`;
    });
    if(tasks.length>4)html+=`<div style="font-size:0.62rem;color:var(--muted);padding:0.1rem 0.5rem">+${tasks.length-4} mais...</div>`;
    html+=`</div></div>`;
  });
  html+='</div>';
  tl.innerHTML=html;
}
function markSRDone(id,btn){
  const s=gs(id),stage=Math.min((s.srStage||0)+1,SR_INT.length-1);
  ss2(id,{srStage:stage,srLastDone:new Date().toISOString(),srTodayDone:true,status:'revisado'});
  btn.textContent='✓ Feito';btn.className='sr-do-btn done-btn';
}

// ════════ CALENDAR ════════
let calD=new Date();
function calNav(dir){calD=new Date(calD.getFullYear(),calD.getMonth()+dir,1);renderCal()}
function autoCI(){if(!DAYS.includes(tdk())){DAYS.push(tdk());save()}}
function doCheckIn(){const k=tdk();if(!DAYS.includes(k)){DAYS.push(k);save()}renderCal();renderStreak();renderHM()}
function getRevDaysInMonth(yr,mo){
  const revDays=new Set();
  ALL.forEach(s=>{
    const dates=getSRDates(s.id)||[];
    dates.forEach(({date})=>{if(date.getFullYear()===yr&&date.getMonth()===mo)revDays.add(date.getDate())});
  });
  return revDays;
}
function renderCal(){
  const yr=calD.getFullYear(),mo=calD.getMonth();
  document.getElementById('calTitle').textContent=new Date(yr,mo,1).toLocaleDateString('pt-BR',{month:'long',year:'numeric'});
  const first=new Date(yr,mo,1).getDay(),days=new Date(yr,mo+1,0).getDate(),today=new Date();
  const revDays=getRevDaysInMonth(yr,mo);
  let h='';
  ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'].forEach(d=>{h+=`<div class="cal-dl">${d}</div>`});
  for(let i=0;i<first;i++)h+=`<div class="cal-day cal-other"></div>`;
  for(let d=1;d<=days;d++){
    const dt=new Date(yr,mo,d),k=dk(dt);
    const isT=dt.toDateString()===today.toDateString(),isFut=dt>today,isSt=DAYS.includes(k),isRev=revDays.has(d);
    let cls='cal-day';
    if(isT)cls+=' cal-today';if(isFut)cls+=' cal-future';
    if(isSt)cls+=' cal-studied';else if(isRev)cls+=' cal-has-rev';
    const click=isFut?'':`onclick="toggleDay('${k}')"`;
    const dot=isRev&&!isSt?`<span class="cal-day-dot"></span>`:'';
    h+=`<div class="${cls}" ${click}>${d}${dot}</div>`;
  }
  document.getElementById('calGrid').innerHTML=h;
  const studied=DAYS.includes(tdk());
  const cb=document.getElementById('checkinBtn');
  cb.className='checkin-btn'+(studied?' done':'');
  cb.textContent=studied?'✓ Estudado hoje!':'✓ Marcar hoje como estudado';
}
function toggleDay(k){const i=DAYS.indexOf(k);if(i>-1)DAYS.splice(i,1);else DAYS.push(k);save();renderCal();renderStreak();renderHM()}
function renderStreak(){
  const today=new Date();let cur=0;
  for(let i=0;i<365;i++){const d=new Date(today);d.setDate(d.getDate()-i);if(DAYS.includes(dk(d)))cur++;else break}
  let best=0,tmp=0;
  const sorted=[...DAYS].sort();
  sorted.forEach((k,i)=>{if(i===0)tmp=1;else{const p=new Date(sorted[i-1]),c=new Date(k);tmp=(c-p)/86400000===1?tmp+1:1}best=Math.max(best,tmp)});
  document.getElementById('sCur').textContent=cur+' dia'+(cur!==1?'s':'');
  document.getElementById('sBest').textContent=best+' dia'+(best!==1?'s':'');
  document.getElementById('sTotal').textContent=DAYS.length;
}
function renderHM(){
  const today=new Date();let h='';
  for(let i=12;i>=0;i--){
    const d=new Date(today);d.setDate(d.getDate()-i);
    const k=dk(d),st=DAYS.includes(k);
    const sess=LOGS.filter(l=>new Date(l.ts).toDateString()===d.toDateString()).length;
    const lv=!st?0:sess>=3?3:sess>=1?2:1;
    h+=`<div class="hm-cell hm-${lv}" title="${k}"></div>`;
  }
  document.getElementById('hmGrid').innerHTML=h;
}

// ════════ EXPERT SCHEDULE ════════
// Priority order based on Pareto 80/20 for nursing residency
const PRIORITY_SUBJECTS=[
  // Top 10 - highest weight (appear most in nursing residency exams)
  'u1','e1','u2','e2','e5','e3','u8','e4','u5','e11',
  // Mid priority
  'u3','u4','e6','e7','u6','e8','e9','e14','u9','e13',
  // Lower priority
  'u10','u11','u12','u13','e15','e16','u16','e23','u17','e12',
  // Remaining
  'u14','u15','u18','u19','u20','u21','e17','e18','e19','e20',
  'u22','u23','u24','u25','u26','u27','u28','e21','e22','e24',
  'e25','e26','e27','e28','e29','e30','e31','e32','e33',
];

// Smart schedule: Mon/Wed = theory (2 subjects), Tue/Thu = questions, Fri = review, Sat PM = light, Sun = rest
const DAY_PLANS=[
  // Mon (0) - Heavy theory session
  {type:'theory',label:'Teoria',blocks:2,time:'2h teoria'},
  // Tue (1) - Questions
  {type:'questions',label:'Questões',blocks:2,time:'1h questões + 30min teoria'},
  // Wed (2) - Theory continued
  {type:'theory',label:'Teoria',blocks:2,time:'2h teoria'},
  // Thu (3) - Questions + SR review
  {type:'mixed',label:'Misto',blocks:2,time:'1h questões + 1h revisão'},
  // Fri (4) - Spaced review day
  {type:'review',label:'Revisão Espaçada',blocks:3,time:'2h revisão'},
  // Sat (5) - Light / rest
  {type:'rest',label:'Descanso',blocks:0,time:'Manhã livre'},
  // Sun (6) - Rest
  {type:'rest',label:'Descanso',blocks:0,time:'Dia livre'},
];

let schedOff=0;
function schedNav(dir){schedOff+=dir;renderSched()}
function getWeek(off){
  const today=new Date(),dow=today.getDay(),mon=new Date(today);
  mon.setDate(today.getDate()-(dow===0?6:dow-1)+(off*7));
  return Array.from({length:7},(_,i)=>{const d=new Date(mon);d.setDate(mon.getDate()+i);return d});
}
function getSubjectForDay(dayIndex, slotIndex, weekOffset){
  // Use a deterministic rotation based on priority order
  const base=(weekOffset*14)+(dayIndex*2)+slotIndex;
  const notStudied=PRIORITY_SUBJECTS.filter(id=>{
    const s=gs(id);return s.status==='nao-estudado'||s.status==='estudando';
  });
  const pool=notStudied.length?notStudied:PRIORITY_SUBJECTS;
  const idx=base%pool.length;
  return ALL.find(s=>s.id===pool[idx]);
}
function getQSubject(dayIndex,weekOffset){
  // Questions on already-studied subjects
  const studied=PRIORITY_SUBJECTS.filter(id=>['estudei','questoes'].includes(gs(id).status));
  if(!studied.length){const p=PRIORITY_SUBJECTS[(dayIndex+(weekOffset*7))%PRIORITY_SUBJECTS.length];return ALL.find(s=>s.id===p)}
  const idx=((dayIndex*3)+(weekOffset*5))%studied.length;
  return ALL.find(s=>s.id===studied[idx]);
}
function getDueSR(date){
  return ALL.filter(s=>{
    const nd=getNextSRDate(s.id);
    return nd&&dk(nd)===dk(date);
  }).slice(0,2);
}

function renderSched(){
  const days=getWeek(schedOff),today=new Date();
  const f=d=>d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
  document.getElementById('schedTitle').textContent=`${f(days[0])} – ${f(days[6])}`;
  const DN=['Seg','Ter','Qua','Qui','Sex','Sáb','Dom'];
  let h='';
  days.forEach((day,i)=>{
    const isT=day.toDateString()===today.toDateString();
    const plan=DAY_PLANS[i];
    const srDue=getDueSR(day);
    let tasks=[];

    if(plan.type==='rest'){
      if(i===5){// Saturday
        tasks.push({type:'t-rest',lbl:'Descanso',name:'Manhã livre – revisar anotações se quiser',time:''});
        const qs=getQSubject(i,schedOff);
        if(qs)tasks.push({type:'t-questions',lbl:'Questões (opcional)',name:qs.name,time:'30min'});
      } else {
        tasks.push({type:'t-rest',lbl:'Descanso Total',name:'Domingo – descanso obrigatório. O cérebro consolida memórias!',time:''});
      }
    } else if(plan.type==='theory'){
      const s1=getSubjectForDay(i,0,schedOff),s2=getSubjectForDay(i,1,schedOff);
      if(s1)tasks.push({type:'t-theory',lbl:'Teoria 1h',name:s1.name,time:'1h teoria'});
      if(s2&&s2.id!==s1?.id)tasks.push({type:'t-theory',lbl:'Teoria 1h',name:s2.name,time:'1h teoria'});
      if(srDue.length)srDue.forEach(s=>tasks.push({type:'t-review',lbl:'Revisão SR',name:s.name,time:'20min'}));
    } else if(plan.type==='questions'){
      const s1=getSubjectForDay(i,0,schedOff);
      if(s1)tasks.push({type:'t-theory',lbl:'Teoria 30min',name:s1.name,time:'30min'});
      const qs=getQSubject(i,schedOff);
      if(qs)tasks.push({type:'t-questions',lbl:'Questões 1h',name:qs.name,time:'1h – 40–60 questões'});
      if(srDue.length)srDue.slice(0,1).forEach(s=>tasks.push({type:'t-review',lbl:'Revisão SR',name:s.name,time:'20min'}));
    } else if(plan.type==='mixed'){
      const qs=getQSubject(i,schedOff);
      if(qs)tasks.push({type:'t-questions',lbl:'Questões 1h',name:qs.name,time:'1h'});
      if(srDue.length){srDue.slice(0,2).forEach(s=>tasks.push({type:'t-review',lbl:'Revisão SR',name:s.name,time:'30min'}))}
      else{const s1=getSubjectForDay(i,0,schedOff);if(s1)tasks.push({type:'t-review',lbl:'Revisão ativa',name:s1.name,time:'1h'})}
    } else if(plan.type==='review'){
      if(srDue.length){
        srDue.forEach(s=>tasks.push({type:'t-review',lbl:'Revisão Espaçada',name:s.name,time:'40min'}));
      }
      const s1=getSubjectForDay(i,0,schedOff),s2=getSubjectForDay(i,1,schedOff);
      if(s1&&tasks.length<3)tasks.push({type:'t-review',lbl:'Revisão ativa',name:s1.name,time:'40min'});
      if(s2&&s2.id!==s1?.id&&tasks.length<3)tasks.push({type:'t-review',lbl:'Mapa Mental',name:s2.name,time:'30min'});
    }

    h+=`<div class="sched-col${isT?' today-col':''}">
      <div class="sched-dh"><div class="sched-dn">${DN[i]}</div><div class="sched-dd">${day.getDate()}</div></div>
      <div class="sched-tasks">`;
    tasks.forEach((t,ti)=>{
      const tk=`${dk(day)}-${ti}`,done=SDONE[tk];
      h+=`<div class="sched-task ${t.type}${done?' t-done':''}" onclick="toggleSD('${tk}',this)">
        <div class="sched-task-type">${t.lbl}</div>
        <div class="sched-task-name">${t.name}</div>
        ${t.time?`<div class="sched-task-time">⏱ ${t.time}</div>`:''}
      </div>`;
    });
    h+=`</div></div>`;
  });
  document.getElementById('schedGrid').innerHTML=h;
}
function toggleSD(k,el){if(SDONE[k])delete SDONE[k];else SDONE[k]=1;save();el.classList.toggle('t-done')}

