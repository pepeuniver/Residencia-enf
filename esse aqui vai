    <button class="q-btn${hasQ?' has-data':''}" onclick="openQModal('${s.id}')" title="Registrar questões">✦${hasQ?`<span class="q-badge">${qd.length}</span>`:''}</button>
    <button class="tim-btn" onclick="startTimerFor('${s.id}')" title="Cronometrar">▶</button>
  </div>`;
}
function dstars(id,def){
  const cur=(gs(id).userDiff)||def;
  let h=`<span class="diff-lbl">Dif:</span>`;
  for(let i=1;i<=4;i++)h+=`<span class="dstar" style="color:${i<=cur?DC[cur]:'#2a2f42'}" onclick="setDiff('${id}',${i})">★</span>`;
  if(cur)h+=`<span style="font-size:0.58rem;color:${DC[cur]};margin-left:2px">${DL[cur]}</span>`;
  return h;
}
