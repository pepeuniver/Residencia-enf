<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Residência Enfermagem – Painel de Estudos</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root{--bg:#0b0d12;--surface:#13161e;--card:#181c28;--border:#262c40;--accent:#4ade80;--accent2:#38bdf8;--accent3:#f59e0b;--accent4:#f87171;--purple:#a78bfa;--text:#e8eaf2;--muted:#5c6480;--radius:12px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(74,222,128,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(74,222,128,0.025) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;z-index:0}
.nav{position:sticky;top:0;z-index:100;background:rgba(11,13,18,0.95);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);display:flex;align-items:center;height:56px;padding:0 1.5rem;gap:0;overflow-x:auto}
.nav::-webkit-scrollbar{display:none}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;letter-spacing:-0.02em;margin-right:1.2rem;white-space:nowrap;flex-shrink:0}
.nav-logo span{color:var(--accent)}
.nav-tabs{display:flex;gap:0;flex-shrink:0}
.nav-tab{background:none;border:none;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:0.8rem;font-weight:500;padding:0 0.85rem;height:56px;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap;flex-shrink:0}
.nav-tab:hover{color:var(--text)}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.nav-sync{margin-left:auto;display:flex;align-items:center;gap:0.5rem;flex-shrink:0}
.sync-code-display{font-family:'DM Mono',monospace;font-size:0.7rem;background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:0.25rem 0.6rem;color:var(--accent2);cursor:pointer;transition:all 0.2s;white-space:nowrap}
.sync-code-display:hover{border-color:var(--accent2)}
.sync-btn{background:rgba(56,189,248,0.1);border:1px solid rgba(56,189,248,0.3);border-radius:7px;color:var(--accent2);font-size:0.72rem;padding:0.28rem 0.6rem;cursor:pointer;transition:all 0.15s;white-space:nowrap}
.sync-btn:hover{background:rgba(56,189,248,0.2)}
.page{display:none;position:relative;z-index:1;max-width:1140px;margin:0 auto;padding:2rem 1.5rem 5rem}
.page.active{display:block}

/* ── TIMER ── */
.timer-layout{display:grid;grid-template-columns:1fr 340px;gap:2rem;align-items:start}
.timer-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:2.5rem 2rem;display:flex;flex-direction:column;align-items:center;gap:1.75rem}
.timer-circle-wrap{position:relative;width:260px;height:260px}
.timer-svg{width:260px;height:260px;transform:rotate(-90deg)}
.timer-track{fill:none;stroke:var(–border);stroke-width:10}
.timer-prog{fill:none;stroke:var(–accent);stroke-width:10;stroke-linecap:round;stroke-dasharray:753.98;stroke-dashoffset:753.98;transition:stroke-dashoffset 1s linear,stroke 0.4s}
.timer-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px}
.timer-digits{font-family:‘DM Mono’,monospace;font-size:3.4rem;font-weight:500;letter-spacing:0.04em;color:var(–accent);line-height:1}
.timer-state-label{font-size:0.68rem;color:var(–muted);text-transform:uppercase;letter-spacing:0.12em}
.subj-display-wrap{text-align:center}
.subj-display-name{font-family:‘Syne’,sans-serif;font-size:0.95rem;font-weight:700;color:var(–text);margin-bottom:2px}
.subj-display-sub{font-size:0.75rem;color:var(–muted)}
.timer-controls{display:flex;gap:1rem;align-items:center}
.tcbtn{border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.18s}
.tcbtn:hover{transform:scale(1.08)}
.tcbtn.sm{width:46px;height:46px;font-size:1rem}
.tcbtn.lg{width:70px;height:70px;font-size:1.5rem}
.tcbtn.play{background:var(–accent);color:#0b0d12}
.tcbtn.pause{background:var(–accent3);color:#0b0d12}
.tcbtn.stop{background:rgba(248,113,113,0.15);border:2px solid var(–accent4);color:var(–accent4)}
.tcbtn.reset{background:rgba(56,189,248,0.12);border:2px solid rgba(56,189,248,0.4);color:var(–accent2)}
.subject-picker-section{width:100%;display:flex;flex-direction:column;gap:0.5rem}
.picker-label{font-size:0.68rem;color:var(–muted);text-transform:uppercase;letter-spacing:0.1em;text-align:center}
.picker-select{background:var(–surface);border:1px solid var(–border);border-radius:10px;color:var(–text);font-family:‘DM Sans’,sans-serif;font-size:0.82rem;padding:0.6rem 1rem;width:100%;cursor:pointer;appearance:none}
.picker-select:focus{outline:none;border-color:var(–accent)}
.log-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:1.5rem}
.log-card h3{font-family:‘Syne’,sans-serif;font-size:0.95rem;margin-bottom:1rem}
.log-list{display:flex;flex-direction:column;gap:0.4rem;max-height:300px;overflow-y:auto}
.log-entry{display:flex;justify-content:space-between;align-items:center;font-size:0.76rem;padding:0.45rem 0.65rem;background:var(–surface);border-radius:7px}
.log-name{color:var(–text);max-width:185px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.log-time{color:var(–accent);font-family:‘DM Mono’,monospace;font-size:0.72rem}
.today-total{margin-top:1rem;padding-top:1rem;border-top:1px solid var(–border);display:flex;justify-content:space-between;align-items:center}
.today-total strong{font-family:‘DM Mono’,monospace;color:var(–accent);font-size:1.1rem}

/* ── SPACED REPETITION PAGE ── */
.sr-layout{display:grid;grid-template-columns:1fr 320px;gap:2rem;align-items:start}
.sr-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:1.75rem}
.sr-card h2{font-family:‘Syne’,sans-serif;font-size:1.1rem;margin-bottom:0.4rem}
.sr-card p{font-size:0.79rem;color:var(–muted);margin-bottom:1.5rem}
.sr-intervals{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem}
.sri{background:var(–surface);border:1px solid var(–border);border-radius:8px;padding:0.4rem 0.75rem;font-size:0.72rem;text-align:center}
.sri-day{font-family:‘Syne’,sans-serif;font-weight:700;font-size:1rem;color:var(–accent)}
.sri-lbl{font-size:0.6rem;color:var(–muted);margin-top:1px}
.sr-today-section{margin-bottom:1.5rem}
.sr-today-section h3{font-family:‘Syne’,sans-serif;font-size:0.9rem;margin-bottom:0.75rem;display:flex;align-items:center;gap:0.5rem}
.sr-badge{display:inline-flex;align-items:center;justify-content:center;background:var(–accent4);color:white;border-radius:50%;width:20px;height:20px;font-size:0.65rem;font-weight:700}
.sr-item{background:var(–surface);border:1px solid var(–border);border-radius:10px;padding:0.7rem 1rem;margin-bottom:0.4rem;display:flex;align-items:center;justify-content:space-between;gap:0.75rem}
.sr-item-name{font-size:0.8rem;font-weight:500;flex:1}
.sr-item-stage{font-size:0.62rem;color:var(–muted);white-space:nowrap}
.sr-do-btn{background:var(–accent);color:#0b0d12;border:none;border-radius:7px;padding:0.28rem 0.65rem;font-size:0.7rem;font-weight:700;cursor:pointer;white-space:nowrap;transition:opacity 0.15s}
.sr-do-btn:hover{opacity:0.8}
.sr-do-btn.done-btn{background:rgba(74,222,128,0.15);color:var(–accent);border:1px solid rgba(74,222,128,0.3);cursor:default}
.sr-timeline{display:flex;flex-direction:column;gap:0;overflow:hidden;border-radius:12px;border:1px solid var(–border)}
.sr-tl-row{display:grid;grid-template-columns:90px 1fr;border-bottom:1px solid var(–border)}
.sr-tl-row:last-child{border:none}
.sr-tl-date{background:var(–surface);padding:0.65rem 0.75rem;font-size:0.72rem;display:flex;flex-direction:column;justify-content:center;border-right:1px solid var(–border)}
.sr-tl-date-day{font-family:‘Syne’,sans-serif;font-weight:700;font-size:0.85rem}
.sr-tl-date-wday{font-size:0.6rem;color:var(–muted);text-transform:uppercase;letter-spacing:0.05em}
.sr-tl-tasks{padding:0.5rem 0.65rem;display:flex;flex-direction:column;gap:0.25rem}
.sr-tl-task{font-size:0.72rem;padding:0.22rem 0.5rem;border-radius:5px;display:flex;align-items:center;gap:0.4rem}
.sr-tl-task.r1{background:rgba(74,222,128,0.1);color:var(–accent)}
.sr-tl-task.r2{background:rgba(56,189,248,0.1);color:var(–accent2)}
.sr-tl-task.r3{background:rgba(245,158,11,0.1);color:var(–accent3)}
.sr-tl-task.r4{background:rgba(167,139,250,0.1);color:var(–purple)}
.sr-tl-task.r5{background:rgba(248,113,113,0.1);color:var(–accent4)}
.sr-stage-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sr-info-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:1.5rem}
.sr-info-card h3{font-family:‘Syne’,sans-serif;font-size:0.95rem;margin-bottom:1rem}
.sr-curve{width:100%;height:90px;margin-bottom:1rem}
.sr-interval-list{display:flex;flex-direction:column;gap:0.5rem}
.sr-int-item{display:flex;align-items:center;gap:0.75rem;font-size:0.78rem}
.sr-int-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.sr-int-info{flex:1;color:var(–muted)}
.sr-int-day{font-family:‘Syne’,sans-serif;font-weight:700;font-size:0.9rem;white-space:nowrap}

/* ── CALENDAR ── */
.cal-layout{display:grid;grid-template-columns:1fr 300px;gap:2rem;align-items:start}
.cal-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:1.75rem}
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem}
.cal-header h2{font-family:‘Syne’,sans-serif;font-size:1.1rem;text-transform:capitalize}
.cal-nbtn{background:var(–surface);border:1px solid var(–border);border-radius:8px;color:var(–text);width:34px;height:34px;cursor:pointer;font-size:1.1rem;transition:all 0.15s}
.cal-nbtn:hover{border-color:var(–accent);color:var(–accent)}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px}
.cal-dl{text-align:center;font-size:0.62rem;color:var(–muted);text-transform:uppercase;letter-spacing:0.06em;padding-bottom:6px}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:9px;font-size:0.82rem;cursor:pointer;border:1px solid transparent;transition:all 0.15s;position:relative;flex-direction:column;gap:1px}
.cal-day:hover:not(.cal-other):not(.cal-future){background:rgba(255,255,255,0.04)}
.cal-other{color:var(–muted);opacity:0.3;cursor:default}
.cal-future{opacity:0.4;cursor:default}
.cal-today{border-color:var(–accent)!important;color:var(–accent);font-weight:700}
.cal-studied{background:rgba(74,222,128,0.15)!important;border-color:rgba(74,222,128,0.35)!important}
.cal-has-rev{background:rgba(245,158,11,0.1)!important;border-color:rgba(245,158,11,0.3)!important}
.cal-day-dot{width:4px;height:4px;border-radius:50%;background:var(–accent3);position:absolute;bottom:4px}
.streak-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:1.5rem}
.streak-card h3{font-family:‘Syne’,sans-serif;font-size:0.95rem;margin-bottom:1rem}
.streak-row{display:flex;justify-content:space-between;align-items:center;padding:0.65rem 0;border-bottom:1px solid var(–border)}
.streak-row:last-of-type{border:none}
.streak-lbl{font-size:0.78rem;color:var(–muted)}
.streak-val{font-family:‘Syne’,sans-serif;font-size:1.4rem;font-weight:800}
.checkin-btn{width:100%;margin-top:1rem;background:var(–accent);color:#0b0d12;border:none;border-radius:12px;padding:0.85rem;font-family:‘Syne’,sans-serif;font-weight:700;font-size:0.9rem;cursor:pointer;transition:all 0.15s}
.checkin-btn:hover{opacity:0.85}
.checkin-btn.done{background:rgba(74,222,128,0.12);color:var(–accent);border:1px solid rgba(74,222,128,0.3);cursor:default}
.hm-grid{display:grid;grid-template-columns:repeat(13,1fr);gap:4px;margin-top:0.75rem}
.hm-cell{aspect-ratio:1;border-radius:3px}
.hm-0{background:var(–border)}.hm-1{background:rgba(74,222,128,0.2)}.hm-2{background:rgba(74,222,128,0.5)}.hm-3{background:rgba(74,222,128,0.85)}

/* ── SCHEDULE ── */
.sched-intro{background:linear-gradient(135deg,rgba(74,222,128,0.07),rgba(56,189,248,0.04));border:1px solid rgba(74,222,128,0.18);border-radius:var(–radius);padding:1.25rem 1.5rem;margin-bottom:1.5rem}
.sched-intro h2{font-family:‘Syne’,sans-serif;font-size:1rem;margin-bottom:0.3rem}
.sched-intro p{font-size:0.79rem;color:var(–muted);line-height:1.5}
.sched-meta{display:flex;flex-wrap:wrap;gap:0.6rem;margin-top:0.75rem}
.sched-chip{background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.25);border-radius:20px;padding:0.2rem 0.65rem;font-size:0.68rem;color:var(–accent)}
.sched-wnav{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem}
.sched-wnav h3{font-family:‘Syne’,sans-serif;font-size:1rem;flex:1;text-align:center}
.wbtn{background:var(–surface);border:1px solid var(–border);border-radius:8px;color:var(–text);padding:0.4rem 0.85rem;cursor:pointer;font-size:0.79rem;transition:all 0.15s}
.wbtn:hover{border-color:var(–accent);color:var(–accent)}
.sched-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:0.55rem}
.sched-col{background:var(–card);border:1px solid var(–border);border-radius:var(–radius);overflow:hidden;min-height:260px}
.sched-col.today-col .sched-dh{background:rgba(74,222,128,0.07);border-color:rgba(74,222,128,0.2)}
.sched-col.today-col .sched-dn{color:var(–accent)}.sched-col.today-col .sched-dd{color:var(–accent)}
.sched-dh{padding:0.55rem 0.4rem;text-align:center;border-bottom:1px solid var(–border)}
.sched-dn{font-family:‘Syne’,sans-serif;font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(–muted)}
.sched-dd{font-size:0.95rem;font-weight:700;margin-top:2px}
.sched-tasks{padding:0.45rem;display:flex;flex-direction:column;gap:0.3rem}
.sched-task{border-radius:6px;padding:0.38rem 0.45rem;font-size:0.64rem;line-height:1.35;cursor:pointer;transition:opacity 0.15s}
.sched-task:hover{opacity:0.75}
.sched-task.t-theory{background:rgba(74,222,128,0.1);border-left:2px solid var(–accent);color:var(–accent)}
.sched-task.t-review{background:rgba(245,158,11,0.1);border-left:2px solid var(–accent3);color:var(–accent3)}
.sched-task.t-questions{background:rgba(167,139,250,0.1);border-left:2px solid var(–purple);color:var(–purple)}
.sched-task.t-rest{background:rgba(92,100,128,0.1);border-left:2px solid var(–muted);color:var(–muted)}
.sched-task.t-done{opacity:0.35;text-decoration:line-through}
.sched-task-type{font-size:0.56rem;text-transform:uppercase;letter-spacing:0.07em;opacity:0.7;margin-bottom:2px}
.sched-task-name{font-weight:500;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical}
.sched-task-time{font-size:0.58rem;opacity:0.65;margin-top:2px}
.sched-legend{display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem;font-size:0.72rem;color:var(–muted)}
.leg-item{display:flex;align-items:center;gap:0.35rem}
.leg-dot{width:10px;height:10px;border-radius:2px}
.sched-rationale{margin-top:2rem;background:var(–card);border:1px solid var(–border);border-radius:var(–radius);padding:1.5rem}
.sched-rationale h3{font-family:‘Syne’,sans-serif;font-size:0.95rem;margin-bottom:0.75rem;color:var(–accent3)}
.sched-rationale p{font-size:0.8rem;color:var(–muted);line-height:1.6;margin-bottom:0.5rem}

/* ── SUBJECTS ── */
.stats-bar{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:1rem;margin-bottom:2rem}
.stat-card{background:var(–card);border:1px solid var(–border);border-radius:var(–radius);padding:1rem 1.25rem;position:relative;overflow:hidden}
.stat-card::before{content:’’;position:absolute;top:0;left:0;width:3px;height:100%}
.s1::before{background:var(–accent)}.s2::before{background:var(–accent2)}.s3::before{background:var(–accent3)}.s4::before{background:var(–accent4)}
.stat-lbl{font-size:0.67rem;color:var(–muted);text-transform:uppercase;letter-spacing:0.08em}
.stat-val{font-family:‘Syne’,sans-serif;font-size:1.8rem;font-weight:800;margin-top:0.2rem}
.rev-alert{background:linear-gradient(135deg,rgba(245,158,11,0.09),rgba(245,158,11,0.03));border:1px solid rgba(245,158,11,0.28);border-radius:var(–radius);padding:1rem 1.5rem;margin-bottom:2rem;display:flex;align-items:flex-start;gap:1rem}
.rev-alert .ico{font-size:1.3rem}.rev-alert h3{font-family:‘Syne’,sans-serif;font-size:0.88rem;color:var(–accent3)}
.rev-alert p{font-size:0.76rem;color:var(–muted);margin-top:0.12rem}
.rev-tags{display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.55rem}
.rev-tag{background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.28);border-radius:20px;padding:0.18rem 0.6rem;font-size:0.67rem;color:var(–accent3);cursor:pointer;transition:background 0.15s}
.rev-tag:hover{background:rgba(245,158,11,0.2)}
.sec-hdr{display:flex;align-items:center;gap:0.9rem;margin-bottom:1.2rem}
.sec-badge{font-family:‘Syne’,sans-serif;font-weight:700;font-size:0.7rem;padding:0.26rem 0.72rem;border-radius:20px;letter-spacing:0.06em}
.badge-uerj{background:rgba(74,222,128,0.1);color:var(–accent);border:1px solid rgba(74,222,128,0.28)}
.badge-enare{background:rgba(56,189,248,0.1);color:var(–accent2);border:1px solid rgba(56,189,248,0.28)}
.sec-title{font-family:‘Syne’,sans-serif;font-size:1.2rem;font-weight:700}
.sec-count{font-size:0.76rem;color:var(–muted);margin-left:auto}
.prog-wrap{margin-bottom:1.5rem}
.prog-bg{height:5px;background:var(–border);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;transition:width 0.5s}
.fill-u{background:linear-gradient(90deg,var(–accent),#22d3ee)}
.fill-e{background:linear-gradient(90deg,var(–accent2),#818cf8)}
.prog-meta{display:flex;justify-content:space-between;font-size:0.67rem;color:var(–muted);margin-top:0.3rem}
.subj-list{display:flex;flex-direction:column;gap:0.5rem}
.subj-item{background:var(–card);border:1px solid var(–border);border-radius:var(–radius);padding:0.82rem 1rem;display:grid;grid-template-columns:26px 1fr auto auto auto;align-items:center;gap:0.6rem;transition:border-color 0.2s,background 0.2s}
.subj-item:hover{border-color:rgba(255,255,255,0.07);background:#1e2234}
.subj-item.due{border-color:rgba(245,158,11,0.32)}
.rank{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:‘Syne’,sans-serif;font-weight:700;font-size:0.66rem;flex-shrink:0}
.r1{background:rgba(248,113,113,0.15);color:var(–accent4)}.r2{background:rgba(245,158,11,0.15);color:var(–accent3)}.r3{background:rgba(56,189,248,0.15);color:var(–accent2)}.r4{background:rgba(74,222,128,0.15);color:var(–accent)}
.subj-name{font-size:0.845rem;font-weight:500;line-height:1.35}
.subj-meta{display:flex;align-items:center;gap:0.45rem;margin-top:0.2rem;flex-wrap:wrap}
.diff-lbl{font-size:0.62rem;color:var(–muted)}
.dstar{font-size:0.88rem;cursor:pointer;transition:transform 0.1s}
.dstar:hover{transform:scale(1.3)}
.rev-badge-s{font-size:0.57rem;padding:0.08rem 0.38rem;border-radius:10px;background:rgba(245,158,11,0.13);color:var(–accent3);border:1px solid rgba(245,158,11,0.28)}
