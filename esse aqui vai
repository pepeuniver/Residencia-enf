}
function drawCharts(subjsWithQ){
  // Bar chart
  const bCanvas=document.getElementById('chartBar');
  const bCtx=bCanvas.getContext('2d');
  bCanvas.width=bCanvas.offsetWidth||480;bCanvas.height=200;
  bCtx.clearRect(0,0,bCanvas.width,bCanvas.height);
  const labels=subjsWithQ.map(s=>s.name.length>18?s.name.slice(0,18)+'…':s.name);
  const pcts=subjsWithQ.map(s=>{const h=QDATA[s.id];const tq=h.reduce((a,b)=>a+b.total,0),tc=h.reduce((a,b)=>a+b.correct,0);return tq?Math.round(tc/tq*100):0});
  const W=bCanvas.width,H=bCanvas.height,pad=40,barW=Math.min(40,(W-pad*2)/labels.length-4);
  const maxV=100;
  bCtx.fillStyle='#262c40';bCtx.fillRect(0,0,W,H);
  // Grid
  for(let g=0;g<=4;g++){
    const y=H-pad-(g/4)*(H-pad*1.5);
    bCtx.strokeStyle='rgba(255,255,255,0.05)';bCtx.beginPath();bCtx.moveTo(pad,y);bCtx.lineTo(W-10,y);bCtx.stroke();
    bCtx.fillStyle='#5c6480';bCtx.font='10px DM Sans';bCtx.textAlign='right';bCtx.fillText(g*25+'%',pad-4,y+3);
  }
  labels.forEach((lbl,i)=>{
    const x=pad+(i+0.5)*(W-pad*1.2)/labels.length;
    const pct=pcts[i],barH=(pct/maxV)*(H-pad*1.5);
    const col=pct>=70?'#4ade80':pct>=50?'#f59e0b':'#f87171';
    bCtx.fillStyle=col+'33';bCtx.fillRect(x-barW/2,H-pad-barH,barW,barH);
    bCtx.fillStyle=col;bCtx.fillRect(x-barW/2,H-pad-barH,barW,3);
    bCtx.fillStyle='#5c6480';bCtx.font='9px DM Sans';bCtx.textAlign='center';
    bCtx.save();bCtx.translate(x,H-pad+4);bCtx.rotate(-Math.PI/4);bCtx.fillText(lbl,0,0);bCtx.restore();
    bCtx.fillStyle=col;bCtx.font='bold 10px DM Sans';bCtx.textAlign='center';bCtx.fillText(pct+'%',x,H-pad-barH-4);
  });

  // Line chart – accuracy over time across all sessions
  const lCanvas=document.getElementById('chartLine');
  const lCtx=lCanvas.getContext('2d');
  lCanvas.width=lCanvas.offsetWidth||480;lCanvas.height=200;
  lCtx.clearRect(0,0,lCanvas.width,lCanvas.height);
  const allSessions=[];
  subjsWithQ.forEach(s=>QDATA[s.id].forEach(h=>allSessions.push({ts:new Date(h.ts),pct:h.total?Math.round(h.correct/h.total*100):0})));
  allSessions.sort((a,b)=>a.ts-b.ts);
  if(allSessions.length<2){lCtx.fillStyle='#262c40';lCtx.fillRect(0,0,lCanvas.width,lCanvas.height);lCtx.fillStyle='#5c6480';lCtx.font='13px DM Sans';lCtx.textAlign='center';lCtx.fillText('Registre pelo menos 2 sessões para ver o gráfico',lCanvas.width/2,100);return}
  const LW=lCanvas.width,LH=lCanvas.height,LP=36;
  lCtx.fillStyle='#262c40';lCtx.fillRect(0,0,LW,LH);
  for(let g=0;g<=4;g++){const y=LH-LP-(g/4)*(LH-LP*1.5);lCtx.strokeStyle='rgba(255,255,255,0.05)';lCtx.beginPath();lCtx.moveTo(LP,y);lCtx.lineTo(LW-10,y);lCtx.stroke();lCtx.fillStyle='#5c6480';lCtx.font='10px DM Sans';lCtx.textAlign='right';lCtx.fillText(g*25+'%',LP-4,y+3)}
  // 70% line
  const y70=LH-LP-(0.7)*(LH-LP*1.5);lCtx.strokeStyle='rgba(74,222,128,0.25)';lCtx.setLineDash([4,4]);lCtx.beginPath();lCtx.moveTo(LP,y70);lCtx.lineTo(LW-10,y70);lCtx.stroke();lCtx.setLineDash([]);
  lCtx.fillStyle='rgba(74,222,128,0.3)';lCtx.font='9px DM Sans';lCtx.textAlign='left';lCtx.fillText('Meta 70%',LP+4,y70-3);
  const pts=allSessions.map((s,i)=>{
    const x=LP+i*(LW-LP-10)/(allSessions.length-1);
    const y=LH-LP-(s.pct/100)*(LH-LP*1.5);
    return{x,y,pct:s.pct};
  });
  // Fill
  lCtx.beginPath();lCtx.moveTo(pts[0].x,LH-LP);pts.forEach(p=>lCtx.lineTo(p.x,p.y));lCtx.lineTo(pts[pts.length-1].x,LH-LP);lCtx.closePath();
  const grad=lCtx.createLinearGradient(0,0,0,LH);grad.addColorStop(0,'rgba(74,222,128,0.25)');grad.addColorStop(1,'rgba(74,222,128,0)');lCtx.fillStyle=grad;lCtx.fill();
  // Line
  lCtx.strokeStyle='#4ade80';lCtx.lineWidth=2;lCtx.beginPath();pts.forEach((p,i)=>i===0?lCtx.moveTo(p.x,p.y):lCtx.lineTo(p.x,p.y));lCtx.stroke();
  // Dots
  pts.forEach(p=>{const col=p.pct>=70?'#4ade80':p.pct>=50?'#f59e0b':'#f87171';lCtx.fillStyle=col;lCtx.beginPath();lCtx.arc(p.x,p.y,4,0,Math.PI*2);lCtx.fill()});
}
function drawEmptyCharts(){
  ['chartBar','chartLine'].forEach(id=>{
    const c=document.getElementById(id);c.width=c.offsetWidth||480;c.height=200;
    const ctx=c.getContext('2d');ctx.fillStyle='#262c40';ctx.fillRect(0,0,c.width,c.height);
    ctx.fillStyle='#5c6480';ctx.font='13px DM Sans';ctx.textAlign='center';ctx.fillText('Registre questões nas matérias para ver gráficos',c.width/2,100);
  });
}

