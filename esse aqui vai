      <div class="sr-interval-list">
        <div class="sr-int-item"><div class="sr-int-dot" style="background:var(--accent)"></div><div class="sr-int-info">1ª revisão após 1 dia</div><div class="sr-int-day">D+1</div></div>
        <div class="sr-int-item"><div class="sr-int-dot" style="background:var(--accent2)"></div><div class="sr-int-info">2ª revisão após 3 dias</div><div class="sr-int-day">D+3</div></div>
        <div class="sr-int-item"><div class="sr-int-dot" style="background:var(--accent3)"></div><div class="sr-int-info">3ª revisão após 1 semana</div><div class="sr-int-day">D+7</div></div>
        <div class="sr-int-item"><div class="sr-int-dot" style="background:var(--purple)"></div><div class="sr-int-info">4ª revisão após 2 semanas</div><div class="sr-int-day">D+14</div></div>
        <div class="sr-int-item"><div class="sr-int-dot" style="background:var(--accent4)"></div><div class="sr-int-info">5ª revisão após 1 mês</div><div class="sr-int-day">D+30</div></div>
