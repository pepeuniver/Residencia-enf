.q-save-btn{background:var(–purple);color:white;border:none;border-radius:8px;padding:0.4rem 0.8rem;font-size:0.78rem;font-weight:600;cursor:pointer;white-space:nowrap}
.q-save-btn:hover{opacity:0.85}
.q-hist{margin-top:0.6rem;font-size:0.72rem;color:var(–muted)}
.q-hist span{color:var(–purple);font-weight:600}

/* ── MODAL/OVERLAY ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.78);backdrop-filter:blur(6px);z-index:200;align-items:center;justify-content:center}
