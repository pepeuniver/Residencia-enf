        <path d="M10,10 Q40,12 60,35 Q80,58 90,62 Q130,70 140,68 Q180,60 200,65 Q230,68 270,66" fill="none" stroke="#f87171" stroke-width="2" stroke-dasharray="4 3"/>
        <path d="M10,10 L30,10 Q32,10 35,18 L38,26 L42,18 L46,12 L50,11 L90,11 Q92,11 95,19 L98,27 L102,19 L106,13 L110,11 L160,11 Q163,11 166,22 L169,32 L173,22 L177,14 L180,11 L270,11" fill="none" stroke="#4ade80" stroke-width="2"/>
        <path d="M10,10 L30,10 Q32,10 35,18 L38,26 L42,18 L46,12 L50,11 L90,11 Q92,11 95,19 L98,27 L102,19 L106,13 L110,11 L160,11 Q163,11 166,22 L169,32 L173,22 L177,14 L180,11 L270,11 L270,90 L10,90 Z" fill="url(#cg)"/>
        <text x="140" y="78" font-size="7" fill="#f87171" text-anchor="middle" font-family="DM Sans">Sem revisão</text>
        <text x="140" y="6" font-size="7" fill="#4ade80" text-anchor="middle" font-family="DM Sans">Com revisão espaçada</text>
